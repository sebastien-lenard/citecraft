# --- Local directories ---
# Directory path to data files used as repositories
LOCAL_REPO_DIR_PATH="C:\Users\Blabla\Documents\Tmp_data\manuscript-reference-lister"
# Log directory path, loaded by logging_config.py (not config.py)
LOG_DIR_PATH="C:\Users\Blabla\Documents\Tmp_data\manuscript-reference-lister"
# Directory path to output files
OUTPUT_DIR_PATH="C:\Users\Blabla\Documents\Tmp_data\manuscript-reference-lister"

# --- Crossref Rest API ---
# url for journal API calls
CROSSREF_API_JOURNALS_URL="https://api.crossref.org/journals"
# url for journal API calls for a specific ISSN (object_name placeholder)
CROSSREF_API_JOURNALS_ISSN_URL="https://api.crossref.org/journals/{object_name}/works"
# url to check reference style validity
CROSSREF_API_STYLES_URL="https://api.crossref.org/styles"
# url for article/reference API calls
CROSSREF_API_WORKS_URL="https://api.crossref.org/works"

# --- Default api/https configuration ---
CROSSREF_API_DELAY=0.5
CROSSREF_API_EMAIL=roger.dupont@gmail.com # email for API calls
CROSSREF_API_WORKS_GET_LIMIT=20 # max number of references retrieved per API call
CROSSREF_API_TIMEOUT=20
CROSSREF_API_MAX_RETRY=10

# --- DOI Content Negotiation Service ---
DOI_API_DELAY=0.4
# Url of the DOI Content Negotiation Service (doi: object_name placeholder)
DOI_API_URL="https://doi.org/{object_name}"
DOI_API_TIMEOUT=10
DOI_API_MAX_RETRY=10

# --- Style remote repository ---
# Csl metadata file specific to an identified parent style name/code, e.g. apa,
# copernicus-publications (style: object_name placeholder)
STYLE_REPO_URL="https://raw.githubusercontent.com/citation-style-language/styles/master/{object_name}.csl"
# Csl metadata file specific to an identified child style name/code, e.g.
# journal-of-geophysical-research-solid-earth (style: object_name placeholder)
CHILD_STYLE_REPO_URL="https://raw.githubusercontent.com/citation-style-language/styles/master/dependent/{object_name}.csl"
# Json file listing journal titles and their official style name/codes.
ALL_STYLES_REPO_URL="https://www.zotero.org/styles-files/styles.json"
# CSL XML style namespaces
CSL_XML_NAMESPACES='{"csl_legacy": "http://purl.org/net/xbiblio/csl", "csl_standard": "http://citationstyles.org/ns/"}'

# --- Values for schemas ---
WORK_CSL_SCHEMA_TYPES=["article", "article-journal", "article-magazine", "article-newspaper", "bill", "book", "broadcast", "chapter", "classic", "collection", "dataset", "document", "entry", "entry-dictionary", "entry-encyclopedia", "event", "figure", "graphic", "hearing", "interview", "legal_case", "legislation", "manuscript", "map", "motion_picture", "musical_score", "pamphlet", "paper-conference", "patent", "performance", "periodical", "personal_communication", "post", "post-weblog", "regulation", "report", "review", "review-book", "song", "speech", "standard", "thesis", "treaty", "webpage"]

# --- Blacklists and cleaners ---
PARSER_BLACKLIST = ["Fig", "Figs", "Figure", "Figures", "Tab", "Table", "Eq", "Plate", "Section", "See", "e.g.", "i.e.", "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"]
WORK_CLS_SCHEMA_BLACKLIST_FIELDS=["URL", "assertion", "content-domain", "is-referenced-by-count", "license", "link", "prefix", "reference", "reference-count", "references-count", "score", "update-policy"]
AUTHOR_CLS_SCHEMA_BLACKLIST_FIELDS=["ORCID", "affiliation", "role"]
PRESERVED_HTML_TAGS=["sup", "sub"]
DISCARDED_HTML_TAGS=["i", "b", "strong", "u", "small"]

# --- Others ---
CONTEXT_KEYWORDS="geosciences hydrology" # field of research for API call

# Days after which journal metadata expire and need to be updated from remote repo (Crossref).
JOURNAL_UPDATE_DAYS=30
# Max number of journals whose metadata can be updated in a row from remote repo (Crossref).
JOURNAL_UPDATE_LIMIT=100

DEFAULT_REFERENCE_STYLE=apa # Default reference style for output